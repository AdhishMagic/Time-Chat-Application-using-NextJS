# ⚠️ SECURITY WARNING ⚠️
# This file documents required environment variables
# DO NOT commit actual credentials or .env.local to version control
# Each developer should create their own .env.local with development values

# MongoDB Connection (Local Development)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=realtime_chat_app

# For production (MongoDB Atlas):
# Use environment variables from your hosting provider (Vercel, AWS, etc.)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# See MONGODB_SETUP.md for detailed instructions

# JWT Secret (generate a long random string)
JWT_SECRET=your-super-secret-key-change-this-in-production
